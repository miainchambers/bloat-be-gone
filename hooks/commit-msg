#!/usr/bin/env bash
set -euo pipefail

# commit-msg hook: validates conventional commit format.
# Install via: bash hooks/install.sh

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits and fixups
if echo "$COMMIT_MSG" | grep -qE "^(Merge|Revert|fixup!|squash!)"; then
  exit 0
fi

# Conventional commits pattern: type(scope)!: description
PATTERN="^(feat|fix|docs|style|refactor|perf|test|chore|ci|revert)(\([a-z0-9_-]+\))?(!)?: .{1,}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "❌ Commit message does not follow Conventional Commits format."
  echo ""
  echo "   Expected: <type>: <description>"
  echo "   Example:  feat: add --exclude flag"
  echo "             fix: handle spaces in project names"
  echo "             chore: update dependencies"
  echo ""
  echo "   Valid types: feat, fix, docs, style, refactor, perf, test, chore, ci, revert"
  echo "   Breaking:    add ! after type — e.g. feat!: rename --keep to --preserve"
  echo "   Note:        type must be lowercase"
  echo ""
  echo "   Your message: $COMMIT_MSG"
  echo ""
  exit 1
fi
